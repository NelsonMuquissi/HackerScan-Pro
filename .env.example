# .env.example - copiar para .env e preencher

# === Django ===
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=hackscan-local-secret-key-12345
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000

# === JWT (RSA) ===
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# === Database ===
# Ajustado para local ports do docker-compose
DATABASE_URL=postgresql://hackscan:hackscan_password@localhost:5432/hackscan_db
TIMESCALE_URL=postgresql://hackscan:hackscan_password@localhost:5432/hackscan_db

# === Redis ===
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=amqp://hackscan:hackscan_password@localhost:5672/

# === Storage ===
AWS_ACCESS_KEY_ID=hackscan_admin
AWS_SECRET_ACCESS_KEY=hackscan_password
AWS_STORAGE_BUCKET_NAME=hackscan-reports
AWS_S3_ENDPOINT_URL=http://localhost:9000

# === Email ===
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@hackscan.pro

# === Stripe ===
STRIPE_SECRET_KEY=sk_test_
STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_WEBHOOK_SECRET=whsec_

# === Anthropic / AI ===
ANTHROPIC_API_KEY=

# === External APIs ===
SHODAN_API_KEY=
CENSYS_API_KEY=
CENSYS_API_SECRET=

# === Vault ===
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=

# === Sentry ===
SENTRY_DSN=

# === Frontend (Next.js) ===
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
