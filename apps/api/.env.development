# ─── HackScan Pro — Development Environment Variables ────────────────────────
# Credentials match docker-compose.yml
# DO NOT commit real secrets — this file stays in .gitignore

DEBUG=True
SECRET_KEY=dev-only-secret-key-change-in-production

# Database (TimescaleDB via docker-compose)
DATABASE_URL=postgresql://hackscan:hackscan_password@localhost:5432/hackscan_db

# Redis (docker-compose)
REDIS_URL=redis://localhost:6379/0

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Email — console backend in development (see settings/development.py)
DEFAULT_FROM_EMAIL=noreply@hackscan.pro

# Frontend URL for email links
FRONTEND_URL=http://localhost:3000

# JWT — HS256 in dev (RS256 keys not required locally)
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# Stripe — test mode keys (get yours at https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=sk_test_
STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_WEBHOOK_SECRET=whsec_

# Anthropic AI (HackerScan Pro Neural Engine)
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_KEY_HERE

# Google Gemini AI (Fallback Engine)
GEMINI_API_KEY=YOUR_GEMINI_KEY_HERE
